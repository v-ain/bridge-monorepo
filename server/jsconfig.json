{
  "compilerOptions": {
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": false,
    "allowImportingTsExtensions": true
  },
  "include": ["**/*.js", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}