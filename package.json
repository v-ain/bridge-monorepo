{
  "name": "bridge-monorepo",
  "version": "1.0.0",
  "description": "Monorepo with shared types, JS server, and React client",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=@bridge-monorepo/shared",
    "check-types": "npm run check-types --workspaces --if-present",
    "dev:shared": "npm run dev --workspace=@bridge-monorepo/shared",
    "dev:server": "npm run dev --workspace=@bridge-monorepo/server",
    "dev:client": "npm run dev --workspace=@bridge-monorepo/client",
    "dev": "npm run build:shared && concurrently \"npm run dev:shared\" \"npm run dev:server\" \"npm run dev:client\"",
    "start:server": "npm run start --workspace server",
    "build:client": "npm run build --workspace client",
    "build": "tsc -b shared && npm run build --workspace client",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "keywords": [
    "monorepo",
    "typescript",
    "nodejs",
    "react"
  ],
  "author": "v-ain",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
