{
  "name": "bridge-monorepo",
  "version": "1.0.0",
  "description": "Monorepo with shared types, JS server, and React client",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "check-types": "npm run check-types --workspace client && npm run check-types --workspace server",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start:server": "npm run start --workspace server",
    "build:client": "npm run build --workspace client"
  },
  "keywords": [
    "monorepo",
    "typescript",
    "nodejs",
    "react"
  ],
  "author": "v-ain",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
